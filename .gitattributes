# 기본: 텍스트 자동 감지 + LF 정규화
* text=auto eol=lf

# 명시적 텍스트 + LF
*.java       text eol=lf
*.kt         text eol=lf
*.kts        text eol=lf
*.gradle     text eol=lf
*.properties text eol=lf
*.xml        text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.json       text eol=lf
*.toml       text eol=lf
*.md         text eol=lf
*.sh         text eol=lf
*.tpl        text eol=lf
Dockerfile   text eol=lf

# Windows 전용 파일은 CRLF 유지
*.bat        text eol=crlf
*.cmd        text eol=crlf

# 바이너리
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.jar  binary
*.zip  binary
*.gz   binary
*.tgz  binary

# linguist hint — 통계 왜곡 줄이기
docs/**           linguist-documentation
gradle/wrapper/** linguist-vendored
gradlew           linguist-vendored
gradlew.bat       linguist-vendored
